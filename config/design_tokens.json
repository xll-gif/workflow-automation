{
  "version": "1.0.0",
  "description": "全局设计令牌配置 - 定义跨平台统一的颜色、间距、字体等样式规范",
  "author": "Workflow Automation System",
  "tokens": {
    "colors": {
      "primary": {
        "default": "#1890ff",
        "hover": "#40a9ff",
        "active": "#096dd9",
        "disabled": "#d9d9d9"
      },
      "success": {
        "default": "#52c41a",
        "hover": "#73d13d",
        "active": "#389e0d"
      },
      "warning": {
        "default": "#faad14",
        "hover": "#ffc53d",
        "active": "#d48806"
      },
      "error": {
        "default": "#ff4d4f",
        "hover": "#ff7875",
        "active": "#cf1322"
      },
      "text": {
        "primary": "#262626",
        "secondary": "#595959",
        "tertiary": "#8c8c8c",
        "disabled": "#bfbfbf",
        "inverse": "#ffffff"
      },
      "background": {
        "default": "#ffffff",
        "secondary": "#fafafa",
        "tertiary": "#f5f5f5",
        "disabled": "#f0f0f0"
      },
      "border": {
        "default": "#d9d9d9",
        "light": "#f0f0f0",
        "dark": "#262626"
      }
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "xxl": 48,
      "xxxl": 64
    },
    "borderRadius": {
      "sm": 4,
      "md": 8,
      "lg": 12,
      "xl": 16,
      "round": 9999
    },
    "fontSize": {
      "xs": 12,
      "sm": 14,
      "md": 16,
      "lg": 18,
      "xl": 20,
      "xxl": 24,
      "xxxl": 32,
      "display": 48
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75,
      "loose": 2
    },
    "fontWeight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "opacity": {
      "disabled": 0.5,
      "hover": 0.8,
      "focus": 0.9
    },
    "shadows": {
      "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
      "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
      "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)"
    },
    "zIndex": {
      "dropdown": 1000,
      "sticky": 1020,
      "fixed": 1030,
      "modalBackdrop": 1040,
      "modal": 1050,
      "popover": 1060,
      "tooltip": 1070
    },
    "transitions": {
      "fast": "150ms ease-in-out",
      "normal": "200ms ease-in-out",
      "slow": "300ms ease-in-out"
    }
  },
  "components": {
    "button": {
      "height": {
        "sm": 32,
        "md": 40,
        "lg": 48
      },
      "padding": {
        "horizontal": 24,
        "vertical": 8
      },
      "fontSize": "md",
      "borderRadius": "md",
      "fontWeight": "semibold"
    },
    "input": {
      "height": {
        "sm": 32,
        "md": 40,
        "lg": 48
      },
      "padding": {
        "horizontal": 16,
        "vertical": 10
      },
      "fontSize": "md",
      "borderRadius": "md",
      "borderColor": "border.default"
    },
    "card": {
      "padding": "lg",
      "borderRadius": "lg",
      "backgroundColor": "background.default",
      "shadow": "md"
    },
    "logo": {
      "width": 80,
      "height": 80,
      "borderRadius": "lg"
    }
  }
}
