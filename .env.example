# 环境变量配置

# GitHub Token
GITHUB_TOKEN=your_github_token_here

# 存储后端配置
STORAGE_BACKEND=cos

# WPT 资源中心配置（腾讯云 COS）
WPT_SCENE_NAME=wechatCx  # 应用场景名称（如 imchat, wechatCx）
WPT_BUSINESS_NAME=kefu  # 业务名称（如 sale, kefu）
WPT_MODE=dev  # 运行环境（dev/gray/prod）
WPT_TOKEN=your_token  # 认证 Token
WPT_SECRET_KEY=your_secret_key  # X-Secret-Key（可选）

# 兼容性配置（旧版，已弃用）
TENCENT_API_BASE_URL=https://skt.weipaitang.com  # 自动根据 mode 选择
TENCENT_SCENE_NAME=wechatCx
TENCENT_BUSINESS_NAME=kefu
TENCENT_MODE=dev
TENCENT_TOKEN=your_token
TENCENT_SECRET_KEY=your_secret_key

# MasterGo 配置
MASTERGO_TOKEN=your_mastergo_token
USE_MOCK_MCP=true

# 大语言模型配置
LLM_API_KEY=your_llm_api_key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4

# 阿里云 OSS 配置（备用）
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET=your_oss_bucket
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
