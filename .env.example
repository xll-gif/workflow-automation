# ============================================
# 工作流自动化环境变量配置
# ============================================

# ============================================
# 存储后端配置（必选其一）
# ============================================
# 存储后端类型: cos（WPT 腾讯云）/ oss（阿里云 OSS）/ mock（仅测试）
STORAGE_BACKEND=mock

# ============================================
# Logo 固定地址（识别 logo 后直接使用此地址）
# ============================================
LOGO_FIXED_URL=https://cdn.weipaitang.com/sky/resourceMan/tupianfv/image/20260303/594f688d556e4a78bd597508c9ebd709-W140H140

# ============================================
# WPT 资源中心配置（腾讯云 COS）
# 当 STORAGE_BACKEND=cos 时需要配置
# ============================================
WPT_MODE=dev                    # 环境模式: dev/gray/prod
WPT_SCENE_NAME=wechatCx         # 场景名称（如 imchat, wechatCx）
WPT_BUSINESS_NAME=kefu          # 业务名称（如 sale, kefu）
WPT_TOKEN=your_token_here       # WPT Token（必填）
WPT_SECRET_KEY=your_secret_key  # WPT Secret Key（必填）

# 向后兼容的旧环境变量（可选，优先使用上面的 WPT_*）
# TENCENT_MODE=dev
# TENCENT_SCENE_NAME=wechatCx
# TENCENT_BUSINESS_NAME=kefu
# TENCENT_TOKEN=your_token_here
# TENCENT_SECRET_KEY=your_secret_here

# ============================================
# 阿里云 OSS 配置
# 当 STORAGE_BACKEND=oss 时需要配置
# ============================================
OSS_ACCESS_KEY_ID=your_access_key_id           # Access Key ID（必填）
OSS_ACCESS_KEY_SECRET=your_access_key_secret   # Access Key Secret（必填）
OSS_BUCKET=your_bucket_name                    # Bucket 名称（必填）
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com  # OSS 端点（必填）

# ============================================
# GitHub 配置（代码提交）
# ============================================
GITHUB_TOKEN=your_github_token_here  # GitHub Token（推送代码）

# ============================================
# MasterGo MCP 配置
# ============================================
USE_MOCK_MCP=true               # 是否使用 Mock MCP（true/false）
# 真实 MasterGo 集成需要额外配置

# ============================================
# 大语言模型配置
# ============================================
LLM_API_KEY=your_llm_api_key    # LLM API Key
LLM_API_BASE=https://api.openai.com/v1  # LLM API Base URL
LLM_MODEL=gpt-4                 # LLM 模型名称

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO                  # 日志级别: DEBUG/INFO/WARNING/ERROR
